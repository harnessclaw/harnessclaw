    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.24.1",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.4.0",
    "tailwindcss-animate": "^1.0.7",
    "ws": "^8.19.0",
    "zustand": "^4.5.4"
