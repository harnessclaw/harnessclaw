{
  "name": "openclaw-nanny",
  "version": "0.5.1",
  "author": "OpenClaw",
  "description": "OpenClaw Gateway desktop client",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/electron-vite-runner.cjs dev",
    "build": "electron-vite build",
    "preview": "node scripts/electron-vite-runner.cjs preview",
    "lint": "eslint . --ext .ts,.tsx",
    "rebuild:electron-native": "electron-builder install-app-deps",
    "bundle:tools": "node scripts/build-bundled-tools.cjs",
    "pack:win": "npm run build && npm run rebuild:electron-native && npm run bundle:tools && electron-builder --dir --win nsis --x64",
    "dist:win": "npm run build && npm run rebuild:electron-native && npm run bundle:tools && electron-builder --win nsis --x64"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "eslint": "^9.24.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
